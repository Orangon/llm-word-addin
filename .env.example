# Anthropic API Key
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Local Word add-in manifest path (used by `npm run update-manifest`)
# The script copies the repo's manifest.xml to this location.
# macOS example:
LOCAL_MANIFEST_PATH=~/Library/Containers/com.microsoft.Word/Data/Documents/wef/manifest.xml
# Windows example:
# LOCAL_MANIFEST_PATH=%LOCALAPPDATA%\Microsoft\Office\16.0\Wef\manifest.xml
